<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="ads-url-001-create-ads-url-table" author="copilot">
        <createTable tableName="ADS_URL">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="CAPMAIN_NAME" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="FULL_URL" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="LANDING_URL" type="VARCHAR(256)"/>
            <column name="URL_SUFFIX" type="VARCHAR(512)"/>
            <column name="PLATFORM" type="VARCHAR(64)"/>
            <column name="REMARK" type="VARCHAR(64)"/>
            <column name="CAMPAIN_OWNER" type="BIGINT">
                <constraints nullable="false" foreignKeyName="FK_ADS_URL_CAMPAIN_OWNER" references="ADS_USER(ID)"/>
            </column>
            <column name="SEQ_NUMBER" type="BIGINT"/>
            <column name="DISPLAY_TIMES" type="BIGINT" defaultValueNumeric="0"/>
            <column name="CREATE_DATE" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATE_DATE" type="TIMESTAMP"/>
            <column name="VERSION" type="BIGINT" defaultValueNumeric="0"/>
        </createTable>
    </changeSet>

    <changeSet id="ads-url-002-create-indexes" author="copilot">
        <createIndex indexName="IDX_ADS_URL_CAPMAIN_NAME" tableName="ADS_URL">
            <column name="CAPMAIN_NAME"/>
        </createIndex>
        <createIndex indexName="IDX_ADS_URL_CAMPAIN_OWNER" tableName="ADS_URL">
            <column name="CAMPAIN_OWNER"/>
        </createIndex>
    </changeSet>

    <changeSet id="ads-url-aud-001-create-ads-url-aud-table" author="copilot">
        <createTable tableName="ADS_URL_AUD">
            <column name="AUD_ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ID" type="BIGINT">
                <constraints nullable="false" foreignKeyName="FK_ADS_URL_AUD_ID" references="ADS_URL(ID)"/>
            </column>
            <column name="CAPMAIN_NAME" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="FULL_URL" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="LANDING_URL" type="VARCHAR(256)"/>
            <column name="URL_SUFFIX" type="VARCHAR(512)"/>
            <column name="PLATFORM" type="VARCHAR(64)"/>
            <column name="REMARK" type="VARCHAR(64)"/>
            <column name="CAMPAIN_OWNER" type="BIGINT">
                <constraints nullable="false" foreignKeyName="FK_ADS_URL_AUD_CAMPAIN_OWNER" references="ADS_USER(ID)"/>
            </column>
            <column name="SEQ_NUMBER" type="BIGINT"/>
            <column name="DISPLAY_TIMES" type="BIGINT" defaultValueNumeric="0"/>
            <column name="CREATE_DATE" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATE_DATE" type="TIMESTAMP"/>
            <column name="VERSION" type="BIGINT" defaultValueNumeric="0"/>
            <column name="REVERSION" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="ads-url-aud-002-create-audit-indexes" author="copilot">
        <createIndex indexName="IDX_ADS_URL_AUD_ID" tableName="ADS_URL_AUD">
            <column name="ID"/>
        </createIndex>
        <createIndex indexName="IDX_ADS_URL_AUD_CAPMAIN_NAME" tableName="ADS_URL_AUD">
            <column name="CAPMAIN_NAME"/>
        </createIndex>
        <createIndex indexName="IDX_ADS_URL_AUD_CREATE_DATE" tableName="ADS_URL_AUD">
            <column name="CREATE_DATE"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
