<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="ads-url-003-shift-link-columns" author="copilot">
        <addColumn tableName="ADS_URL">
            <column name="CAMPAIN_NAME" type="VARCHAR(32)"/>
            <column name="CAMPAIN_COUNTRY" type="VARCHAR(8)"/>
            <column name="LANDING_PAGE_URL" type="VARCHAR(128)"/>
            <column name="PLATFORM_NAME" type="VARCHAR(32)"/>
            <column name="REMARKS" type="VARCHAR(64)"/>
            <column name="ADS_OWNER" type="VARCHAR(32)"/>
            <column name="ADS_TYPE" type="VARCHAR(16)"/>
            <column name="CAMPAIN_ID" type="BIGINT"/>
            <column name="DISPLAY_NUMBER" type="BIGINT"/>
            <column name="STATUS" type="VARCHAR(16)"/>
        </addColumn>

        <modifyDataType tableName="ADS_URL" columnName="CAPMAIN_NAME" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ADS_URL" columnName="LANDING_URL" newDataType="VARCHAR(128)"/>
        <modifyDataType tableName="ADS_URL" columnName="URL_SUFFIX" newDataType="VARCHAR(256)"/>
        <modifyDataType tableName="ADS_URL" columnName="PLATFORM" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ADS_URL" columnName="REMARK" newDataType="VARCHAR(64)"/>
    </changeSet>

    <changeSet id="ads-url-004-shift-link-audit-columns" author="copilot">
        <dropForeignKeyConstraint baseTableName="ADS_URL_AUD" constraintName="FK_ADS_URL_AUD_ID"/>
        <addColumn tableName="ADS_URL_AUD">
            <column name="CAMPAIN_NAME" type="VARCHAR(32)"/>
            <column name="CAMPAIN_COUNTRY" type="VARCHAR(8)"/>
            <column name="LANDING_PAGE_URL" type="VARCHAR(128)"/>
            <column name="PLATFORM_NAME" type="VARCHAR(32)"/>
            <column name="REMARKS" type="VARCHAR(64)"/>
            <column name="ADS_OWNER" type="VARCHAR(32)"/>
            <column name="ADS_TYPE" type="VARCHAR(16)"/>
            <column name="CAMPAIN_ID" type="BIGINT"/>
            <column name="DISPLAY_NUMBER" type="BIGINT"/>
            <column name="STATUS" type="VARCHAR(16)"/>
        </addColumn>

        <modifyDataType tableName="ADS_URL_AUD" columnName="CAPMAIN_NAME" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ADS_URL_AUD" columnName="LANDING_URL" newDataType="VARCHAR(128)"/>
        <modifyDataType tableName="ADS_URL_AUD" columnName="URL_SUFFIX" newDataType="VARCHAR(256)"/>
        <modifyDataType tableName="ADS_URL_AUD" columnName="PLATFORM" newDataType="VARCHAR(32)"/>
        <modifyDataType tableName="ADS_URL_AUD" columnName="REMARK" newDataType="VARCHAR(64)"/>
    </changeSet>

    <changeSet id="ads-url-005-shift-link-indexes" author="copilot">
        <createIndex indexName="IDX_ADS_URL_PLATFORM_NAME" tableName="ADS_URL">
            <column name="PLATFORM_NAME"/>
        </createIndex>
        <createIndex indexName="IDX_ADS_URL_STATUS" tableName="ADS_URL">
            <column name="STATUS"/>
        </createIndex>
        <createIndex indexName="IDX_ADS_URL_ADS_OWNER" tableName="ADS_URL">
            <column name="ADS_OWNER"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
