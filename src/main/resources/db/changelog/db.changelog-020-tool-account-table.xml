<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="tool-account-001-create-table" author="copilot">
        <createTable tableName="TOOL_ACCOUNT">
            <column name="ID" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="EMAIL_ADDRESS" type="VARCHAR(64)">
                <constraints foreignKeyName="FK_TOOL_ACCOUNT_EMAIL_ADDRESS" references="TOOL_EMAL(EMAIL_ADDRESS)"/>
            </column>
            <column name="USER_NAME" type="VARCHAR(16)">
                <constraints foreignKeyName="FK_TOOL_ACCOUNT_USER_NAME" references="TOOL_EMAL(USER_NAME)"/>
            </column>
            <column name="PLATFORM_NAME" type="VARCHAR(32)">
                <constraints foreignKeyName="FK_TOOL_ACCOUNT_PLATFORM_NAME" references="ADS_PLATFORM(PLATFORM_NAME)"/>
            </column>
            <column name="PAYMENT_STATUS" type="VARCHAR(32)"/>
            <column name="STATUS" type="VARCHAR(32)"/>
            <column name="REGISTER_DATE" type="DATE"/>
            <column name="BALANCE" type="DECIMAL(19,4)"/>
            <column name="CURRENCY" type="VARCHAR(32)"/>
            <column name="REMARKS" type="VARCHAR(64)"/>
            <column name="ADS_OWNER" type="VARCHAR(32)">
                <constraints nullable="false"
                             foreignKeyName="FK_TOOL_ACCOUNT_ADS_OWNER"
                             references="ADS_USER(USER_PHONE_NUMBER)"/>
            </column>
            <column name="CREATE_DATE" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATE_DATE" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="tool-account-002-create-indexes" author="copilot">
        <createIndex indexName="IDX_TOOL_ACCOUNT_ADS_OWNER" tableName="TOOL_ACCOUNT">
            <column name="ADS_OWNER"/>
        </createIndex>
        <createIndex indexName="IDX_TOOL_ACCOUNT_USER_NAME" tableName="TOOL_ACCOUNT">
            <column name="USER_NAME"/>
        </createIndex>
        <createIndex indexName="IDX_TOOL_ACCOUNT_STATUS" tableName="TOOL_ACCOUNT">
            <column name="STATUS"/>
        </createIndex>
        <createIndex indexName="IDX_TOOL_ACCOUNT_EMAIL_ADDRESS" tableName="TOOL_ACCOUNT">
            <column name="EMAIL_ADDRESS"/>
        </createIndex>
        <createIndex indexName="IDX_TOOL_ACCOUNT_PLATFORM_NAME" tableName="TOOL_ACCOUNT">
            <column name="PLATFORM_NAME"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
