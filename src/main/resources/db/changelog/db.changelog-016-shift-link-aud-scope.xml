<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="shift-link-aud-001-add-scope-columns" author="copilot">
        <addColumn tableName="SHIFT_LINK_AUD">
            <column name="ADS_OWNER" type="VARCHAR(32)"/>
            <column name="ADS_NAME" type="VARCHAR(32)"/>
            <column name="ADS_TYPE" type="VARCHAR(16)"/>
            <column name="SEQ_NUMBER" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="shift-link-aud-002-add-scope-index" author="copilot">
        <createIndex indexName="IDX_SHIFT_LINK_AUD_SCOPE" tableName="SHIFT_LINK_AUD">
            <column name="ADS_OWNER"/>
            <column name="ADS_NAME"/>
            <column name="ADS_TYPE"/>
            <column name="OPERATION_DATE"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
